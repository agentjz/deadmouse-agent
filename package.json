{
  "name": "@jun133/kitty",
  "version": "0.0.1",
  "description": "Agent",
  "license": "MIT",
  "keywords": [
    "kitty",
    "agent",
    "automation",
    "runtime",
    "harness"
  ],
  "bin": {
    "kitty": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets/web-workbench",
    "README.md",
    "README.en.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format cjs --platform node --target node20 --outDir dist --clean --sourcemap",
    "check": "npm run typecheck && npm run build",
    "dev": "tsx src/cli.ts",
    "test:build": "node -e \"require('node:fs').rmSync('.test-build', { recursive: true, force: true })\" && tsc -p tsconfig.tests.json",
    "test:core": "npm run test:build && node --test .test-build/tests/**/*.test.js",
    "verify:repo-contracts": "tsx tests/production-line/verify-repo-contracts.ts",
    "verify": "npm run verify:repo-contracts && npm test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "prepublishOnly": "npm run build",
    "test": "npm run check && npm run test:core"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.9.0",
    "@monaco-editor/loader": "^1.5.0",
    "better-sqlite3": "^12.8.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.1",
    "cors": "^2.8.6",
    "diff": "^8.0.2",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "execa": "^9.6.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "figlet": "^1.11.0",
    "lowdb": "^7.0.1",
    "marked": "^17.0.4",
    "monaco-editor": "^0.55.1",
    "openai": "^6.4.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
